<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ===================== CARD STYLES ===================== -->
    <style name="Widget.A1Gym.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/colorSurface</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/stroke_subtle</item>
    </style>

    <!-- ===================== TEXT INPUT STYLES ===================== -->
    <style name="Widget.A1Gym.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.FilledBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxBackgroundColor">@color/shimmer_bg</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxStrokeColor">@color/colorPrimary</item>
        <item name="hintTextColor">@color/colorPrimary</item>
    </style>

    <style name="Widget.A1Gym.TextInputLayout.Dropdown" parent="Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxBackgroundColor">@color/shimmer_bg</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxStrokeColor">@color/colorPrimary</item>
        <item name="hintTextColor">@color/colorPrimary</item>
    </style>

    <!-- ===================== BUTTON STYLES ===================== -->
    <style name="Widget.A1Gym.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.A1Gym.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="strokeColor">@color/colorPrimary</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="rippleColor">@color/colorPrimaryLight</item>
    </style>

    <style name="Widget.A1Gym.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="rippleColor">@color/colorPrimaryLight</item>
    </style>

    <!-- ===================== BOTTOM NAVIGATION ===================== -->
    <style name="Widget.A1Gym.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="backgroundTint">@color/colorSurface</item>
        <item name="itemIconTint">@color/bottom_nav_selector</item>
        <item name="itemTextColor">@color/bottom_nav_selector</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemRippleColor">@color/colorPrimaryLight</item>
        <item name="elevation">8dp</item>
    </style>

    <!-- ===================== FAB ===================== -->
    <style name="Widget.A1Gym.FAB" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="tint">@color/white</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.A1Gym.FAB</item>
        <item name="elevation">6dp</item>
    </style>

    <style name="ShapeAppearance.A1Gym.FAB" parent="">
        <item name="cornerSize">16dp</item>
    </style>

    <!-- ===================== SECTION HEADER ===================== -->
    <style name="TextAppearance.A1Gym.SectionTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.0</item>
    </style>

    <style name="TextAppearance.A1Gym.CardTitle" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.A1Gym.CardValue" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <!-- ===================== CHIP / FILTER TAB ===================== -->
    <style name="Widget.A1Gym.Chip.Filter" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipCornerRadius">20dp</item>
        <item name="chipBackgroundColor">@color/chip_bg_selector</item>
        <item name="android:textColor">@color/chip_text_selector</item>
        <item name="chipStrokeColor">@color/divider</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipMinHeight">36dp</item>
        <item name="android:textSize">13sp</item>
        <item name="checkedIconVisible">false</item>
    </style>

</resources>
