<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.A1GymManager" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorSecondaryVariant">@color/colorAccent</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background & Surface -->
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/colorStatusBar</item>

        <!-- Text Input Style -->
        <item name="textInputStyle">@style/Widget.A1Gym.TextInputLayout</item>

        <!-- Card Style -->
        <item name="materialCardViewStyle">@style/Widget.A1Gym.CardView</item>

        <!-- Button Styles -->
        <item name="materialButtonStyle">@style/Widget.A1Gym.Button</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.A1Gym.Button.Outlined</item>

        <!-- Bottom Navigation -->
        <item name="bottomNavigationStyle">@style/Widget.A1Gym.BottomNav</item>

        <!-- Floating Action Button -->
        <item name="floatingActionButtonStyle">@style/Widget.A1Gym.FAB</item>
    </style>
</resources>
