<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="black">#000000</color>
    <color name="bottom_nav_inactive">#9CA3AF</color>
    <color name="colorAccent">#4CAF50</color>
    <color name="colorBackground">#F8F9FA</color>
    <color name="colorOnPrimary">#FFFFFF</color>
    <color name="colorOnSurface">#111827</color>
    <color name="colorPrimary">#2D3B8F</color>
    <color name="colorPrimaryLight">#E8EAF6</color>
    <color name="colorPrimaryVariant">#1A2560</color>
    <color name="colorSecondary">#4CAF50</color>
    <color name="colorStatusBar">#1A2560</color>
    <color name="colorSurface">#FFFFFF</color>
    <color name="divider">#E5E7EB</color>
    <color name="icon_bg_active">#E8F5E9</color>
    <color name="icon_bg_expired">#FEE2E2</color>
    <color name="icon_bg_members">#E8EAF6</color>
    <color name="icon_bg_revenue">#FFF3E0</color>
    <color name="icon_tint_active">#4CAF50</color>
    <color name="icon_tint_expired">#EF4444</color>
    <color name="icon_tint_members">#2D3B8F</color>
    <color name="icon_tint_revenue">#FF9800</color>
    <color name="shimmer_bg">#F3F4F6</color>
    <color name="status_active">#4CAF50</color>
    <color name="status_active_bg">#E8F5E9</color>
    <color name="status_expired">#EF4444</color>
    <color name="status_expired_bg">#FEE2E2</color>
    <color name="status_expiring_soon">#F59E0B</color>
    <color name="status_expiring_soon_bg">#FEF3C7</color>
    <color name="stroke_subtle">#F3F4F6</color>
    <color name="text_hint">#9CA3AF</color>
    <color name="text_primary">#111827</color>
    <color name="text_secondary">#6B7280</color>
    <color name="white">#FFFFFF</color>
    <string name="action_add_member">Add Member</string>
    <string name="action_generate_invoice">Generate Invoice</string>
    <string name="app_name">A1 Gym Manager</string>
    <string name="status_active">Active</string>
    <string name="status_expired">Expired</string>
    <string name="status_expiring_soon">Expiring Soon</string>
    <string name="title_dashboard">Dashboard</string>
    <string name="title_members">Members</string>
    <string name="title_payments">Payments</string>
    <string name="title_settings">Settings</string>
    <style name="ShapeAppearance.A1Gym.FAB" parent="">
        <item name="cornerSize">16dp</item>
    </style>
    <style name="TextAppearance.A1Gym.CardTitle" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="TextAppearance.A1Gym.CardValue" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>
    <style name="TextAppearance.A1Gym.SectionTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.0</item>
    </style>
    <style name="Theme.A1GymManager" parent="Theme.MaterialComponents.Light.NoActionBar">
        
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorOnPrimary">@color/white</item>

        
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorSecondaryVariant">@color/colorAccent</item>
        <item name="colorOnSecondary">@color/white</item>

        
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/text_primary</item>

        
        <item name="android:statusBarColor">@color/colorStatusBar</item>

        
        <item name="textInputStyle">@style/Widget.A1Gym.TextInputLayout</item>

        
        <item name="materialCardViewStyle">@style/Widget.A1Gym.CardView</item>

        
        <item name="materialButtonStyle">@style/Widget.A1Gym.Button</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.A1Gym.Button.Outlined</item>

        
        <item name="bottomNavigationStyle">@style/Widget.A1Gym.BottomNav</item>

        
        <item name="floatingActionButtonStyle">@style/Widget.A1Gym.FAB</item>
    </style>
    <style name="Widget.A1Gym.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="backgroundTint">@color/colorSurface</item>
        <item name="itemIconTint">@color/bottom_nav_selector</item>
        <item name="itemTextColor">@color/bottom_nav_selector</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemRippleColor">@color/colorPrimaryLight</item>
        <item name="elevation">8dp</item>
    </style>
    <style name="Widget.A1Gym.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="Widget.A1Gym.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="strokeColor">@color/colorPrimary</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="rippleColor">@color/colorPrimaryLight</item>
    </style>
    <style name="Widget.A1Gym.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="rippleColor">@color/colorPrimaryLight</item>
    </style>
    <style name="Widget.A1Gym.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/colorSurface</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/stroke_subtle</item>
    </style>
    <style name="Widget.A1Gym.Chip.Filter" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipCornerRadius">20dp</item>
        <item name="chipBackgroundColor">@color/chip_bg_selector</item>
        <item name="android:textColor">@color/chip_text_selector</item>
        <item name="chipStrokeColor">@color/divider</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipMinHeight">36dp</item>
        <item name="android:textSize">13sp</item>
        <item name="checkedIconVisible">false</item>
    </style>
    <style name="Widget.A1Gym.FAB" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="tint">@color/white</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.A1Gym.FAB</item>
        <item name="elevation">6dp</item>
    </style>
    <style name="Widget.A1Gym.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.FilledBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxBackgroundColor">@color/shimmer_bg</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxStrokeColor">@color/colorPrimary</item>
        <item name="hintTextColor">@color/colorPrimary</item>
    </style>
    <style name="Widget.A1Gym.TextInputLayout.Dropdown" parent="Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxBackgroundColor">@color/shimmer_bg</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxStrokeColor">@color/colorPrimary</item>
        <item name="hintTextColor">@color/colorPrimary</item>
    </style>
</resources>